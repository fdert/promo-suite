@echo off
REM ============================================================
REM update.bat — ضعه داخل مجلد promo-suite نفسه (بجانب مجلد frontend)
REM شغّله بالنقر المزدوج في أي وقت بعد تعديل أي ملف لرفع التحديث تلقائيًا.
REM ============================================================

cd /d "%~dp0"

echo ============================================
echo   جاري سحب آخر التحديثات من GitHub...
echo ============================================
git pull origin main --no-rebase
if errorlevel 1 (
  echo.
  echo تعذر السحب التلقائي - قد تحتاج حل تعارض يدويًا.
  echo راجع الرسائل أعلاه، ثم شغّل هذا الملف مرة أخرى.
  pause
  exit /b 1
)

echo.
echo ============================================
echo   جاري إضافة كل التعديلات...
echo ============================================
git add .

set "msg="
set /p msg="اكتب وصف التحديث (أو اضغط Enter مباشرة لوصف تلقائي): "
if "%msg%"=="" set "msg=تحديث تلقائي %date% %time%"

git commit -m "%msg%"

echo.
echo ============================================
echo   جاري الرفع إلى GitHub...
echo ============================================
git push origin main

echo.
echo ============================================
echo   تم! راقب النشر التلقائي على الرابط التالي:
echo   https://github.com/fdert/promo-suite/actions
echo ============================================
echo.
pause
